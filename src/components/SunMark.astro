---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = 'glyph', size = 34 } = Astro.props;
---
<img
  class={className}
  src="/ava-logo-128.png"
  srcset="/ava-logo-128.png 1x, /ava-logo-512.png 2x"
  width={size}
  height={size}
  alt=""
  aria-hidden="true"
  decoding="async"
  loading="eager"
/>
